{
  "$schema": "https://schema.tauri.app/config/2",

  "productName": "FastShot",
  "version":     "1.0.0",
  "identifier":  "com.fastshot.app",

  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label":       "main",
        "title":       "FastShot \u2014 Settings",
        "width":       480,
        "height":      520,
        "resizable":   false,
        "center":      true,
        "visible":     false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "closable":    true
      }
    ],
    "trayIcon": {
      "iconPath":       "icons/icon.png",
      "iconAsTemplate": true
    }
  },

  "bundle": {
    "active":  true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode":             "currentUser",
        "shortcutName":            "FastShot"
      }
    }
  },

  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl":             "http://localhost:1420",
    "frontendDist":       "../dist"
  },

  "plugins": {
    "shell": { "open": true }
  }
}
